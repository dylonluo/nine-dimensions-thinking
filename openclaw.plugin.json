{
  "id": "cognitive-pilot",
  "name": "CognitivePilot",
  "version": "1.0.0",
  "description": "认知领航员 - 个人成长系统",
  "kind": "tool",
  "main": "index.ts",
  "tools": [
    {
      "name": "review",
      "description": "对输入进行九维思考框架分析",
      "parameters": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "input": {
            "type": "string",
            "description": "要分析的内容"
          },
          "framework": {
            "type": "string",
            "enum": [
              "four-questions",
              "six-dimensions",
              "nine-masters"
            ],
            "description": "指定框架（可选，默认自动选择）"
          },
          "format": {
            "type": "string",
            "enum": [
              "markdown",
              "json"
            ],
            "description": "输出格式（可选，默认 markdown）"
          }
        },
        "required": [
          "input"
        ]
      }
    }
  ]
}
